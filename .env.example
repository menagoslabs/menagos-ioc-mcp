# -----------------------------------------------------------------------------
# menagos-ioc-mcp configuration
# Copy to .env and fill in real values. Never commit .env.
# -----------------------------------------------------------------------------

# --- API keys ----------------------------------------------------------------
# VirusTotal and AbuseIPDB require keys (free tier OK).
VT_API_KEY=
ABUSEIPDB_API_KEY=

# GreyNoise Community accepts unauthenticated requests. Leave blank unless
# you have a key, authenticated calls get slightly higher quotas.
GREYNOISE_API_KEY=

# --- Transport ---------------------------------------------------------------
# stdio (default, for Claude Desktop / Claude Code) or http (local testing)
TRANSPORT=stdio

# Local HTTP bind, only used when TRANSPORT=http.
# Always bind loopback unless you know what you're doing.
HTTP_HOST=127.0.0.1
HTTP_PORT=8765

# --- Timeouts (seconds) ------------------------------------------------------
# Total wall-clock budget for a single lookup_ioc call.
REQUEST_TIMEOUT_S=10
# Per-provider timeout. Must be less than REQUEST_TIMEOUT_S.
PROVIDER_TIMEOUT_S=6

# --- Rate limiting -----------------------------------------------------------
# In-process token bucket per provider, requests per minute.
PROVIDER_RATE_LIMIT_PER_MIN=60

# --- Logging -----------------------------------------------------------------
LOG_LEVEL=INFO
# When false, indicator values are truncated in logs for safety.
# Set true only for local debugging.
LOG_FULL_INDICATORS=false
